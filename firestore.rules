// Firestore 보안 규칙 (최종본)
// households/{가족코드} 아래 데이터에만, 로그인(익명 포함)된 요청이 접근 가능.
// 옛 경로(budgets/·meta/)는 마이그레이션이 끝나 더 이상 허용하지 않습니다(암묵적 거부).
//
// ※ 한계: 이 규칙은 "로그인 + 올바른 경로"까지만 강제합니다. 가족코드(hid)는
//    추측 불가능한 랜덤값이지만, 코드를 아는 사람은 접근할 수 있습니다(링크 공유형 모델).
//    사용자별 강제가 필요하면 실명 로그인 + 멤버 검사가 필요합니다.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /households/{hid} {
      match /{document=**} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
