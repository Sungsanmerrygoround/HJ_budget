// Firestore 보안 규칙
// Firebase 콘솔 → Firestore Database → 규칙(Rules) 탭에 그대로 붙여넣고 "게시(Publish)".
//
// 뜻: 로그인한 사용자는 "자기 uid 폴더(users/내uid)" 아래 데이터만 읽고 쓸 수 있다.
//     남의 데이터는 접근 불가.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
