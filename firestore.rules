// Firestore 보안 규칙
// Firebase 콘솔 → Firestore Database → 규칙(Rules) 탭에 붙여넣고 "게시(Publish)".
//
// 뜻: (익명 포함) 로그인된 요청만 가족 공용 데이터(budgets, meta)에 접근 가능.
//     로그인 안 한 외부 스크립트의 직접 접근은 막힙니다.
//     ※ 가족끼리 공유하는 구조라, 로그인된 사용자는 모두 같은 데이터를 봅니다.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /budgets/{doc} {
      allow read, write: if request.auth != null;
    }
    match /meta/{doc} {
      allow read, write: if request.auth != null;
    }
  }
}
